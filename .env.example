# Template — kopiere zu .env und fülle die Werte ein.
# Die echte .env wird NICHT in git committed (siehe .gitignore).

# SportsDataIO MLB API-Key
# https://sportsdata.io/  → Developer Portal → Subscriptions
SPORTSDATAIO_MLB_KEY=

# (Optional) MLB Stats API benötigt keinen Key — die freie statsapi.mlb.com
# wird ohne Authentifizierung genutzt. Hier nichts einzutragen.

# --- Gurobi (Green-field-Solver; Einrichtung: python -m tools.setup_gurobi) ---
# Weg A: Named-User/Academic — Aktivierungscode auf DIESEM Rechner im Uni-Netz
#        einlösen (Code ist EINMALIG + maschinengebunden; nie in Sandboxen):
#   python -m tools.setup_gurobi --key <aktivierungscode>
#   → setzt automatisch: GRB_LICENSE_FILE=/Users/<du>/gurobi.lic
# GRB_LICENSE_FILE=

# Weg B: WLS (portal.gurobi.com → Licenses → Academic WLS; container-tauglich,
#        damit kann auch eine Cloud-/Review-Session große Instanzen rechnen):
# GRB_WLSACCESSID=
# GRB_WLSSECRET=
# GRB_LICENSEID=

# Voll-Lizenz beweisen (löst ein Modell ÜBER dem Restricted-Limit):
#   python -m tools.setup_gurobi --validate

# --- OpenRouteService (optional, nur Ops-Routing 5.5) ---
# ORS_API_KEY=
